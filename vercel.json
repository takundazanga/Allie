const GROUPS = ['NurSara','Liberation Studio','Sasce','Ventures & Business','Creative & Craft'];

// ── RENDER SKILLS ──────────────────────────────────────────────
function renderSkills() {
  document.getElementById('skills-body').innerHTML = GROUPS.map(g => {
    const items = SKILLS.filter(s => s.g === g);
    return `<div class="sk-group">
      <div class="sk-lbl">${g}</div>
      <div class="sk-grid">${items.map(s => `
        <div class="sk-card" style="--c:${s.c}" onclick="openSkill('${s.name.replace(/'/g,"\\'")}')">
          <div class="sk-top"><span class="sk-domain">${s.domain}</span><span class="sk-type">${s.type}</span></div>
          <div class="sk-name">${s.name}</div>
          <div class="sk-desc">${s.desc}</div>
          <div class="sk-tags">${s.projects.map(p=>`<span class="sk-proj">${p}</span>`).join('')}</div>
          <div class="sk-bar-row">
            <div class="sk-bar"><div class="sk-fill" style="width:${s.p}%;background:${s.c}"></div></div>
            <span class="sk-pct">${s.p}%</span>
          </div>
        </div>`).join('')}
      </div>
    </div>`;
  }).join('');
}

// ── VIEW ───────────────────────────────────────────────────────
function switchView(v, btn) {
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.top-btn').forEach(el=>el.classList.remove('active'));
  document.getElementById(`view-${v}`).classList.add('active');
  btn.classList.add('active');
}

// ── MODE & CTX ─────────────────────────────────────────────────
const MODE_PH = {
  think:'Think out loud…', write:'Tell me what to write…',
  challenge:'Give me the idea. I\'ll find the gaps…',
  edit:'Paste what you\'re working on…', build:'What are we building…'
};
const CTX_LBL = {
  full:'full stack', nursara:'nursara', sasce:'sasce',
  liberation:'liberation studio', lbls:'lost but loving still', thaw:'thaw / pie'
};

function setMode(m, el) {
  const prev = mode; mode = m;
  document.querySelectorAll('.sb-sec:nth-child(1) .sb-item').forEach(i=>i.classList.remove('active'));
  el.classList.add('active');
  updateBadge();
  document.getElementById('main-ta').placeholder = MODE_PH[m];
  if (prev !== m && history.length > 0) {
    addBanner(`${m.charAt(0).toUpperCase()+m.slice(1)} mode — fresh thread`);
    history = [];
  }
}

function setCtx(el, c) {
  const prev = ctx; ctx = c;
  document.querySelectorAll('.sb-sec:nth-child(2) .sb-item').forEach(i=>i.classList.remove('active'));
  el.classList.add('active');
  updateBadge();
  if (prev !== c && history.length > 0) {
    addBanner(`Context: ${CTX_LBL[c]} — fresh thread`);
    history = [];
  }
}

function updateBadge() {
  document.getElementById('mode-badge').textContent = `${mode} · ${CTX_LBL[ctx]}`;
}

function addBanner(text) {
  const feed = document.getElementById('feed');
  const div = document.createElement('div');
  div.className = 'reg-banner';
  div.innerHTML = `<span class="reg-banner-icon">↺</span><span class="reg-banner-text">${text}</span>`;
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

// ── FRESH START ────────────────────────────────────────────────
function freshStart() {
  history = [];
  document.getElementById('feed').innerHTML = `
    <div class="welcome" id="welcome">
      <div class="welcome-mark">A</div>
      <div class="welcome-title">Fresh start. What's on your mind?</div>
      <div class="welcome-body">Context is still loaded — just clearing the thread.</div>
      <div class="chips">
        <button class="chip" onclick="quick('Where should I focus today?')">Where to focus</button>
        <button class="chip" onclick="quick('New idea — help me think it through.')">New idea</button>
        <button class="chip" onclick="quick('What am I quietly avoiding right now?')">What am I avoiding?</button>
      </div>
    </div>`;
}

// ── CHAT ───────────────────────────────────────────────────────
function quick(t) { document.getElementById('main-ta').value=t; sendMain(); }
function mainKey(e) { if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMain();} }
function resize(el) { el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,130)+'px'; }
function now() { return new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}); }
function fmt(t) {
  return t
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/\n\n/g,'</p><p style="margin-top:9px">')
    .replace(/\n/g,'<br>');
}

function addMsg(role, text) {
  document.getElementById('welcome')?.remove();
  const feed = document.getElementById('feed');
  const div = document.createElement('div');
  div.className = `msg ${role}`;
  div.innerHTML = `<div class="msg-meta"><span class="msg-author">${role==='user'?'Taku':'Allie'}</span><span class="msg-time">${now()}</span></div><div class="msg-body">${fmt(text)}</div>`;
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

function addThinking(id) {
  document.getElementById('welcome')?.remove();
  const feed = document.getElementById('feed');
  const div = document.createElement('div');
  div.className = 'msg allie'; div.id = id;
  div.innerHTML = `<div class="msg-meta"><span class="msg-author">Allie</span></div><div class="thinking"><div class="dots"><span></span><span></span><span></span></div><span class="thinking-text">with you…</span></div>`;
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

async function sendMain() {
  if (busy) return;
  const ta = document.getElementById('main-ta');
  const text = ta.value.trim();
  if (!text) return;
  busy = true;
  document.getElementById('main-send').disabled = true;
  ta.value = ''; ta.style.height = 'auto';
  addMsg('user', text);
  history.push({role:'user',content:text});
  addThinking('main-t');
  const sys = ALLIE.replace('{MODE}',mode.toUpperCase()).replace('{CTX}',CTX_LBL[ctx].toUpperCase());
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:sys,messages:history})
    });
    const data = await res.json();
    const reply = data.content?.[0]?.text || 'Something went wrong.';
    document.getElementById('main-t')?.remove();
    addMsg('allie', reply);
    history.push({role:'assistant',content:reply});
  } catch {
    document.getElementById('main-t')?.remove();
    addMsg('allie','Connection issue — are we inside claude.ai?');
  }
  busy = false;
  document.getElementById('main-send').disabled = false;
  ta.focus();
}

// ── SKILL MODAL ────────────────────────────────────────────────
function openSkill(name) {
  const s = SKILLS.find(x=>x.name===name);
  if (!s) return;
  currentSkill = s; skillHistory = [];
  document.getElementById('m-title').textContent = s.name;
  document.getElementById('m-sub').textContent = s.domain;
  document.getElementById('m-feed').innerHTML = '';
  document.getElementById('m-ta').value = '';
  document.getElementById('overlay').classList.add('open');
  kickSkill(s);
}

function closeModal() {
  document.getElementById('overlay').classList.remove('open');
  currentSkill = null; skillHistory = [];
}

function modalKey(e) { if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendModal();} }

function addLearn(role, text) {
  const feed = document.getElementById('m-feed');
  const div = document.createElement('div');
  div.className = `learn${role==='user'?' user':''}`;
  div.innerHTML = fmt(text);
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

function addSkillThinking() {
  const feed = document.getElementById('m-feed');
  const div = document.createElement('div');
  div.className = 'learn'; div.id = 'sk-t';
  div.innerHTML = `<div class="thinking"><div class="dots"><span></span><span></span><span></span></div><span class="thinking-text">going deep…</span></div>`;
  feed.appendChild(div);
  feed.scrollTop = feed.scrollHeight;
}

async function kickSkill(s) {
  skillHistory.push({role:'user',content:s.prompt});
  addSkillThinking();
  const sys = SKILL_SYS.replace('{SKILL}',s.name).replace('{DOMAIN}',s.domain);
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:sys,messages:skillHistory})
    });
    const data = await res.json();
    const reply = data.content?.[0]?.text || 'Something went wrong.';
    document.getElementById('sk-t')?.remove();
    addLearn('allie', reply);
    skillHistory.push({role:'assistant',content:reply});
  } catch {
    document.getElementById('sk-t')?.remove();
    addLearn('allie','Connection issue.');
  }
}

async function sendModal() {
  if (skillBusy || !currentSkill) return;
  const ta = document.getElementById('m-ta');
  const text = ta.value.trim();
  if (!text) return;
  skillBusy = true;
  document.getElementById('m-send').disabled = true;
  ta.value = ''; ta.style.height = 'auto';
  addLearn('user', text);
  skillHistory.push({role:'user',content:text});
  addSkillThinking();
  const sys = SKILL_SYS.replace('{SKILL}',currentSkill.name).replace('{DOMAIN}',currentSkill.domain);
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:sys,messages:skillHistory})
    });
    const data = await res.json();
    const reply = data.content?.[0]?.text || 'Something went wrong.';
    document.getElementById('sk-t')?.remove();
    addLearn('allie', reply);
    skillHistory.push({role:'assistant',content:reply});
  } catch {
    document.getElementById('sk-t')?.remove();
    addLearn('allie','Connection issue.');
  }
  skillBusy = false;
  document.getElementById('m-send').disabled = false;
  ta.focus();
}

// ── INIT ───────────────────────────────────────────────────────
renderSkills();
document.getElementById('overlay').addEventListener('click', e=>{if(e.target===e.currentTarget)closeModal();});
</script>
</body>
</html>
